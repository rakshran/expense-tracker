# Gmail user ID. Use "me" for the authenticated account, or your email address.
GMAIL_USER_ID=me

# The ID of the Gmail label that tags your expense emails (e.g. Label_1234567890).
GMAIL_LABEL_ID=Label_1234567890

# Directory where exported CSV files are written.
OUTPUT_DIR=output

# Path to your Google OAuth client credentials file.
CREDENTIALS_FILE=credentials.json

# Path where the OAuth token is cached after the first run.
TOKEN_FILE=token.json
